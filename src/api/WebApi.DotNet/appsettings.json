{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "DefaultModel": "llama3.2",
    "Timeout": "00:00:30"
  },
  "Embeddings": {
    "OllamaBaseUrl": "http://localhost:11434",
    "Model": "nomic-embed-text",
    "Timeout": "00:01:00"
  },
  "Assistant": {
    "SystemPrompt": "You are a helpful meal planning assistant.",
    "MaximumToolCallsPerRequest": 10,
    "MaximumConversationSize": 100,
    "MaximumExecutionTime": "00:02:00"
  },
  "ConversationStore": {
    "RedisConnectionString": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "MaximumConversations": 1000,
    "MaximumMessagesPerConversation": 50,
    "AutomaticTrimming": true,
    "ExpirationTimeout": "01:00:00"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5001"
      }
    }
  }
}